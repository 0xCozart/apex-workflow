{
  "version": 1,
  "name": "service-desk",
  "description": "Non-Minty example profile for a small service desk app with no tracker, graph tooling, or browser automation.",
  "operatorCautions": [],
  "authority": {
    "productTruth": ["PRODUCT.md"],
    "executionTruth": [],
    "workflowRules": ["AGENTS.md"],
    "doNotUseAsAuthority": []
  },
  "orientation": {
    "readFirst": ["AGENTS.md"],
    "readBeforeBroadSearch": ["README.md"],
    "sectionedDocs": []
  },
  "modes": [
    {
      "id": "tiny",
      "useWhen": "Single known file, low risk, no durable tracker state.",
      "requiredGates": ["direct file read", "path-scoped check"],
      "codeFacing": true
    },
    {
      "id": "route-local",
      "useWhen": "One owner with obvious callers.",
      "requiredGates": ["manifest", "owner/contract read", "focused checks"],
      "codeFacing": true
    },
    {
      "id": "planning",
      "useWhen": "Product, design, or architecture decision before code.",
      "requiredGates": ["durable plan artifact when useful"],
      "codeFacing": false
    }
  ],
  "tracker": {
    "provider": "none",
    "project": null,
    "authorityRule": "Tracker reflects execution state when configured; this app has no durable tracker.",
    "recordWhen": ["medium or large change", "follow-up or coordination need"],
    "dispositions": ["none", "blocked"]
  },
  "codeIntelligence": {
    "provider": "focused-search",
    "availability": {
      "configuredPreference": "focused-search",
      "detectedRepoSupport": "not-required",
      "currentHostAvailability": "not-required",
      "fallbackCommandReadiness": "not-required"
    },
    "mcp": null,
    "wrapperFallback": null,
    "statusCommand": null,
    "refreshCommand": null,
    "queryCommand": null,
    "contextCommand": null,
    "impactCommand": null,
    "detectCommand": null,
    "freshnessGate": {
      "enabled": false,
      "policy": "Not required for focused-search."
    },
    "fallback": "Use focused source search and route through README, PRODUCT.md, and contracts.",
    "confidenceByTarget": {
      "symbol": "advisory",
      "type": "advisory",
      "module": "advisory",
      "file_path": "measure",
      "new_file": "measure",
      "manifest_file": "measure",
      "script": "measure",
      "workflow": "measure",
      "documentation": "advisory"
    },
    "requireFor": [],
    "advisoryFor": ["documentation"],
    "skipFor": [],
    "fallbackEvidence": "focused_source_review"
  },
  "contracts": {
    "featureArtifacts": ["docs/feature-artifacts"],
    "stateContracts": ["docs/state-contracts"],
    "surrogates": ["README.md"]
  },
  "verification": {
    "focusedChecksFirst": true,
    "requiredCommands": ["npm test"],
    "optionalCommands": [],
    "freshnessInputs": ["package.json"],
    "envAllowlist": [],
    "knownFailures": null,
    "browser": {
      "provider": "none",
      "origin": null,
      "artifacts": null,
      "policy": "Use an explicit skip reason when browser verification is not relevant."
    },
    "defaultPreset": "focused",
    "broadChecksRunLast": true,
    "expensiveCommandPolicy": {
      "maxConcurrentJobs": 1,
      "warnAfterSeconds": 120
    },
    "presets": {
      "focused": {
        "commands": ["npm test"]
      },
      "docs_only": {
        "commands": ["git diff --check"],
        "skipBroadBuild": true
      }
    }
  },
  "uiUx": {
    "designSystemDocs": [],
    "visualSignoff": "human",
    "browserEvidencePolicy": "functional-only unless this profile explicitly allows visual signoff"
  },
  "manifest": {
    "defaultDir": "tmp/apex-workflow",
    "finishPacket": [
      "What landed",
      "Mode",
      "Downshift proof",
      "Owned files",
      "No-touch preserved",
      "Verified commands",
      "Failed / skipped checks",
      "Manual evidence",
      "GitNexus freshness",
      "Code-intelligence scope",
      "Tracker update",
      "Next safe slice"
    ]
  },
  "profileDiscovery": {
    "enabled": true,
    "observationLog": "tmp/apex-workflow/observations.jsonl",
    "recommendAfterManifests": 10,
    "recommendAfterDays": 7
  },
  "operatingModel": {
    "default": "ledger",
    "allowed": ["ledger", "assisted", "executor"],
    "executeCommandDefault": "disabled",
    "reason": "Use Apex for scope, evidence, and repo-calibrated workflow guidance unless this repo explicitly opts into stronger execution."
  },
  "manifestPolicy": {
    "directory": "tmp/apex-workflow",
    "requiredWhen": [
      "multi_file_change",
      "dirty_worktree_present",
      "shared_surface_change",
      "install_or_release_change",
      "security_sensitive_change",
      "operator_requested_evidence"
    ],
    "optionalWhen": ["single_file_low_risk_change", "docs_only_change"],
    "deferWhen": ["exploratory_debugging", "single_command_diagnosis", "owned_files_unknown"],
    "deferredMode": {
      "name": "measurement_debugging",
      "recordsCommands": true,
      "requiresOwnedFiles": false,
      "requiresDetect": false
    }
  },
  "sliceTemplates": {},
  "finishPacket": {
    "requireOperatorQuestions": false,
    "include": [
      "summary",
      "owned_files",
      "no_touch_files",
      "commands_run",
      "commands_failed_or_skipped",
      "evidence",
      "detect_result",
      "remaining_risk",
      "next_safe_slice"
    ]
  }
}
